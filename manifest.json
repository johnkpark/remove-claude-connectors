{
  "manifest_version": 3,
  "name": "Claude Connector Remover",
  "version": "0.1.0",
  "description": "Find and remove remote MCP connectors from Claude's connectors page.",
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/customize/connectors*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-agent.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ]
}
